@Cart.API_HostAddress = http://localhost:5288

### Create a new cart
POST {{Cart.API_HostAddress}}/Cart
Content-Type: application/json

{
  "userId": "test-user"
}

### Get cart by ID
GET {{Cart.API_HostAddress}}/Cart/11111111-1111-1111-1111-111111111111
Accept: application/json

### Add item to cart
POST {{Cart.API_HostAddress}}/Cart/11111111-1111-1111-1111-111111111111/items
Content-Type: application/json

{
  "productId": 1001,
  "productName": "Sneakers",
  "quantity": 1,
  "price": 79.99,
  "currency": "EUR"
}

### Remove item from cart
DELETE {{Cart.API_HostAddress}}/Cart/11111111-1111-1111-1111-111111111111/items/1001

### Health check
GET {{Cart.API_HostAddress}}/Health
Accept: application/json
